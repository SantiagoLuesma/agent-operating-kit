#!/usr/bin/env bash
# Structural integrity checks for the agent kit (and project instances).
# Exit: 0 pass | 1 fail
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=lib/common.sh
source "$ROOT/scripts/lib/common.sh"
cd "$ROOT"

errors=0
warnings=0

fail() {
  kit_fail "$*"
  errors=$((errors + 1))
}

warn() {
  kit_warn "$*"
  warnings=$((warnings + 1))
}

ok() {
  kit_ok "$*"
}

note() {
  kit_info "$*"
}

require_nonempty_file() {
  local f="$1"
  if [[ ! -f "$f" ]]; then
    fail "missing required file: $f"
    return 1
  fi
  if [[ ! -s "$f" ]]; then
    fail "required file is empty: $f"
    return 1
  fi
  ok "found $f"
}

# --- Required core files ---
for f in \
  AGENTS.md \
  VERSION \
  TOOLING.md \
  CLAUDE.md \
  README.md \
  SECURITY.md \
  CHANGELOG.md \
  docs/project-status.md \
  docs/product/scope.md \
  docs/kit/scripts.md \
  docs/kit/completeness.md \
  profiles/quick.md \
  profiles/standard.md \
  profiles/full.md \
  adapters/generic-prompt.md \
  contracts/README.md \
  docs/_templates/project-status.md \
  docs/features/_templates/spec.md \
  docs/features/_templates/test-plan.md \
  docs/features/_templates/open-questions.md \
  docs/features/_templates/review.md \
  docs/features/README.md \
  docs/plans/_templates/exec-plan.md \
  docs/plans/_templates/release.md \
  docs/handoffs/_templates/handoff.md \
  docs/decisions/adr/_template.md \
  docs/architecture/_templates/review.md \
  docs/product/_templates/validation-summary.md \
  docs/product/_templates/experiments.md
do
  require_nonempty_file "$f" || true
done

# --- Skeleton docs must not be zero-byte ---
skeleton_dirs=(
  docs/product
  docs/ux
  docs/architecture
  docs/runbooks
)
for d in "${skeleton_dirs[@]}"; do
  if [[ ! -d "$d" ]]; then
    fail "missing skeleton directory: $d"
    continue
  fi
  while IFS= read -r -d '' f; do
    # skip templates subdirs if any under these (architecture has _templates)
    case "$f" in
      */_templates/*) continue ;;
    esac
    if [[ ! -s "$f" ]]; then
      fail "skeleton file is empty: $f"
    fi
  done < <(find "$d" -type f -name '*.md' -print0)
done
ok "skeleton markdown files are non-empty (product/ux/architecture/runbooks)"

# Must include Skeleton form marker on canonical skeletons (best-effort)
for f in \
  docs/product/problem.md \
  docs/ux/information-architecture.md \
  docs/architecture/system-context.md \
  docs/runbooks/incident-response.md
do
  if [[ -f "$f" ]] && ! grep -q 'Skeleton form' "$f"; then
    warn "expected skeleton marker in $f"
  fi
done

# --- Scripts ---
for s in check-docs verify test list-skills bootstrap-project smoke-level-b; do
  if [[ -f "scripts/$s" ]]; then
    if [[ -x "scripts/$s" ]]; then
      ok "executable scripts/$s"
    else
      fail "not executable: scripts/$s"
    fi
  else
    fail "missing scripts/$s"
  fi
done

if [[ -f "scripts/lib/common.sh" ]]; then
  ok "found scripts/lib/common.sh"
else
  fail "missing scripts/lib/common.sh"
fi

# --- VERSION ---
if [[ -f VERSION ]]; then
  ver="$(tr -d '[:space:]' < VERSION)"
  if semver_ok "$ver"; then
    ok "VERSION is semver: $ver"
  else
    fail "VERSION is not valid semver: '$ver'"
  fi
fi

# --- Skills inventory ---
if [[ ! -d ".agents/skills" ]]; then
  fail "missing .agents/skills directory"
else
  skill_count=0
  while IFS= read -r -d '' skill; do
    skill_count=$((skill_count + 1))
    dir_name="$(basename "$(dirname "$skill")")"

    if ! head -1 "$skill" | grep -q '^---$'; then
      fail "skill missing opening frontmatter ---: $skill"
      continue
    fi

    if ! awk 'NR>1 && $0=="---" { found=1; exit } END { exit !found }' "$skill"; then
      fail "skill missing closing frontmatter ---: $skill"
    fi

    name="$(frontmatter_field "$skill" "name" | head -1 | tr -d '\r')"
    desc="$(frontmatter_field "$skill" "description" | head -1 | tr -d '\r')"

    if [[ -z "${name:-}" ]]; then
      fail "skill missing frontmatter name: $skill"
    else
      if [[ "$name" != "$dir_name" ]]; then
        fail "skill name '$name' != directory '$dir_name' ($skill)"
      fi
    fi

    if [[ -z "${desc:-}" ]]; then
      fail "skill missing frontmatter description: $skill"
    fi
  done < <(find .agents/skills -mindepth 2 -maxdepth 2 -name SKILL.md -print0 | sort -z)

  if [[ "$skill_count" -eq 0 ]]; then
    fail "no skills found under .agents/skills"
  else
    ok "$skill_count skills with SKILL.md"
  fi
fi

# --- AGENTS.md catalog table vs disk ---
if [[ -f AGENTS.md && -d .agents/skills ]]; then
  catalog_tmp="$(mktemp)"
  disk_tmp="$(mktemp)"

  grep -E '^\|[^|]+\| `([a-z0-9]+(-[a-z0-9]+)+)`' AGENTS.md \
    | sed -E 's/.*`([a-z0-9]+(-[a-z0-9]+)+)`.*/\1/' \
    | sort -u > "$catalog_tmp" || true

  find .agents/skills -mindepth 1 -maxdepth 1 -type d -exec basename {} \; \
    | sort -u > "$disk_tmp"

  missing=0
  while IFS= read -r skill_id; do
    [[ -z "$skill_id" ]] && continue
    if [[ ! -d ".agents/skills/$skill_id" ]]; then
      fail "AGENTS.md catalogs skill not on disk: $skill_id"
      missing=$((missing + 1))
    fi
  done < "$catalog_tmp"

  while IFS= read -r dir_skill; do
    [[ -z "$dir_skill" ]] && continue
    if ! grep -qx "$dir_skill" "$catalog_tmp"; then
      warn "skill on disk not listed in AGENTS.md catalog table: $dir_skill"
    fi
  done < "$disk_tmp"

  if [[ "$missing" -eq 0 ]]; then
    ok "AGENTS.md skill catalog matches disk (table entries)"
  fi

  rm -f "$catalog_tmp" "$disk_tmp"
fi

# --- No example-feature noise required ---
if [[ -d docs/features/example-feature-1 ]]; then
  warn "docs/features/example-feature-1 still present; prefer templates only"
fi

# --- Suspicious markers in core kit text ---
if grep -R --line-number -E 'TODO\(|FIXME\(|xxxSECRET|AKIA[0-9A-Z]{16}' \
  AGENTS.md TOOLING.md README.md SECURITY.md profiles adapters scripts docs/kit 2>/dev/null \
  | grep -v 'check-docs' \
  | grep -v 'common.sh' \
  | grep -v 'NOT CONFIGURED' \
  | grep -v 'TODO markers' \
  | grep .; then
  fail "suspicious markers found in core kit files"
else
  ok "no suspicious markers in core kit docs/scripts"
fi

# --- Summary ---
if [[ "$warnings" -gt 0 ]]; then
  note "check-docs: $warnings warning(s)"
fi

if [[ "$errors" -gt 0 ]]; then
  kit_fail "check-docs: $errors error(s)"
  exit "$KIT_EXIT_FAIL"
fi

kit_log "check-docs: passed"
exit "$KIT_EXIT_OK"
