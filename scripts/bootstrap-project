#!/usr/bin/env bash
# Copy this kit into a target project directory (new or existing).
#
# Usage:
#   scripts/bootstrap-project /path/to/project
#   scripts/bootstrap-project /path/to/project --force
#
# Copies portable kit files. Does not copy .git or invent product content.
# Existing files are skipped unless --force is set.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=lib/common.sh
source "$ROOT/scripts/lib/common.sh"

if [[ $# -lt 1 ]]; then
  cat <<'USAGE' >&2
Usage: scripts/bootstrap-project <target-dir> [--force]

Copies the agent kit into <target-dir> for use in a software project.
USAGE
  exit "$KIT_EXIT_FAIL"
fi

TARGET="$1"
FORCE=0
if [[ "${2:-}" == "--force" ]]; then
  FORCE=1
fi

if [[ "$TARGET" == "$ROOT" ]]; then
  kit_fail "refusing to bootstrap into the kit root itself"
  exit "$KIT_EXIT_FAIL"
fi

mkdir -p "$TARGET"

copy_file() {
  local src="$1"
  local dest="$2"
  if [[ ! -e "$ROOT/$src" ]]; then
    kit_warn "skip missing source: $src"
    return 0
  fi
  mkdir -p "$(dirname "$TARGET/$dest")"
  if [[ -e "$TARGET/$dest" && "$FORCE" -ne 1 ]]; then
    kit_info "skip existing: $dest"
    return 0
  fi
  cp "$ROOT/$src" "$TARGET/$dest"
  kit_ok "copied $dest"
}

copy_tree() {
  local src="$1"
  local dest="$2"
  if [[ ! -d "$ROOT/$src" ]]; then
    kit_warn "skip missing tree: $src"
    return 0
  fi
  mkdir -p "$TARGET/$dest"
  # copy contents; skip if dest file exists unless force
  (
    cd "$ROOT/$src"
    find . -type f | while IFS= read -r rel; do
      rel="${rel#./}"
      mkdir -p "$TARGET/$dest/$(dirname "$rel")"
      if [[ -e "$TARGET/$dest/$rel" && "$FORCE" -ne 1 ]]; then
        kit_info "skip existing: $dest/$rel"
      else
        cp "$ROOT/$src/$rel" "$TARGET/$dest/$rel"
        # preserve executability for scripts
        if [[ -x "$ROOT/$src/$rel" ]]; then
          chmod +x "$TARGET/$dest/$rel"
        fi
        kit_ok "copied $dest/$rel"
      fi
    done
  )
}

kit_info "bootstrap: kit=$ROOT"
kit_info "bootstrap: target=$TARGET force=$FORCE"

# Root kit files
for f in AGENTS.md CLAUDE.md TOOLING.md VERSION CONTRIBUTING.md; do
  copy_file "$f" "$f"
done

# Do not overwrite a product README if present unless forced — use kit README only for greenfield
if [[ ! -f "$TARGET/README.md" || "$FORCE" -eq 1 ]]; then
  if [[ -f "$TARGET/README.md" && "$FORCE" -eq 1 ]]; then
    copy_file "README.md" "README.kit.md"
    kit_info "wrote kit README as README.kit.md (force mode preserves awareness)"
  else
    # For new projects, install a short instance README pointer instead of the kit manifesto
    cat > "$TARGET/README.md" <<EOF
# Project

This repository uses the **agent operating kit** (version $(tr -d '[:space:]' < "$ROOT/VERSION")).

- Rules: \`AGENTS.md\`
- Skills: \`.agents/skills/\`
- Status: \`docs/project-status.md\`
- Profiles: \`profiles/\`
- Verify: \`./scripts/verify\`

See \`TOOLING.md\` for agent/model-agnostic usage.
Bootstrap source kit version recorded below.

\`\`\`text
kit_version: $(tr -d '[:space:]' < "$ROOT/VERSION")
\`\`\`
EOF
    kit_ok "wrote project README.md stub"
  fi
else
  kit_info "skip existing: README.md"
fi

copy_tree ".agents" ".agents"
copy_tree "profiles" "profiles"
copy_tree "adapters" "adapters"
copy_tree "scripts" "scripts"

# Docs: templates + skeleton, not fictional product
copy_tree "docs/_templates" "docs/_templates"
copy_tree "docs/features/_templates" "docs/features/_templates"
copy_tree "docs/plans/_templates" "docs/plans/_templates"
copy_tree "docs/handoffs/_templates" "docs/handoffs/_templates"
copy_tree "docs/decisions" "docs/decisions"

copy_file "docs/product/scope.md" "docs/product/scope.md"
copy_file "docs/_templates/project-status.md" "docs/project-status.md"
copy_file "contracts/README.md" "contracts/README.md"
copy_file ".github/pull_request_template.md" ".github/pull_request_template.md"
copy_file ".gitignore" ".gitignore"

# Ensure script executables
if [[ -d "$TARGET/scripts" ]]; then
  chmod +x "$TARGET/scripts/check-docs" "$TARGET/scripts/verify" "$TARGET/scripts/test" \
    "$TARGET/scripts/list-skills" "$TARGET/scripts/bootstrap-project" 2>/dev/null || true
fi

# Record kit version stamp
mkdir -p "$TARGET/docs"
{
  echo "# Kit bootstrap stamp"
  echo
  echo "- kit_version: $(tr -d '[:space:]' < "$ROOT/VERSION")"
  echo "- bootstrapped_at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  echo "- source: agent operating kit"
} > "$TARGET/docs/kit-version.md"
kit_ok "wrote docs/kit-version.md"

kit_log "bootstrap: done"
kit_info "next: edit docs/project-status.md and run discover-product or audit-existing-project"
exit "$KIT_EXIT_OK"
