#!/usr/bin/env bash
# Copy this kit into a target project directory (new or existing).
#
# Usage:
#   scripts/bootstrap-project /path/to/project
#   scripts/bootstrap-project /path/to/project --force
#
# Copies the portable kit surface so the target is check-docs capable.
# Does not invent product facts. Existing files are skipped unless --force.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=lib/common.sh
source "$ROOT/scripts/lib/common.sh"

if [[ $# -lt 1 ]]; then
  cat <<'USAGE' >&2
Usage: scripts/bootstrap-project <target-dir> [--force]

Copies the agent kit into <target-dir> for use in a software project.
USAGE
  exit "$KIT_EXIT_FAIL"
fi

TARGET="$1"
FORCE=0
if [[ "${2:-}" == "--force" ]]; then
  FORCE=1
fi

if [[ "$TARGET" == "$ROOT" ]]; then
  kit_fail "refusing to bootstrap into the kit root itself"
  exit "$KIT_EXIT_FAIL"
fi

# Resolve absolute target when possible
mkdir -p "$TARGET"
TARGET="$(cd "$TARGET" && pwd)"

copy_file() {
  local src="$1"
  local dest="${2:-$1}"
  if [[ ! -e "$ROOT/$src" ]]; then
    kit_warn "skip missing source: $src"
    return 0
  fi
  mkdir -p "$(dirname "$TARGET/$dest")"
  if [[ -e "$TARGET/$dest" && "$FORCE" -ne 1 ]]; then
    kit_info "skip existing: $dest"
    return 0
  fi
  cp "$ROOT/$src" "$TARGET/$dest"
  if [[ -x "$ROOT/$src" ]]; then
    chmod +x "$TARGET/$dest"
  fi
  kit_ok "copied $dest"
}

copy_tree() {
  local src="$1"
  local dest="${2:-$1}"
  if [[ ! -d "$ROOT/$src" ]]; then
    kit_warn "skip missing tree: $src"
    return 0
  fi
  mkdir -p "$TARGET/$dest"
  (
    cd "$ROOT/$src"
    find . -type f | while IFS= read -r rel; do
      rel="${rel#./}"
      # never copy local-only noise
      case "$rel" in
        .DS_Store|*/.DS_Store) continue ;;
      esac
      mkdir -p "$TARGET/$dest/$(dirname "$rel")"
      if [[ -e "$TARGET/$dest/$rel" && "$FORCE" -ne 1 ]]; then
        kit_info "skip existing: $dest/$rel"
      else
        cp "$ROOT/$src/$rel" "$TARGET/$dest/$rel"
        if [[ -x "$ROOT/$src/$rel" ]]; then
          chmod +x "$TARGET/$dest/$rel"
        fi
        kit_ok "copied $dest/$rel"
      fi
    done
  )
}

kit_info "bootstrap: kit=$ROOT"
kit_info "bootstrap: target=$TARGET force=$FORCE"

# Detect pre-existing product status before we copy kit docs
had_project_status=0
if [[ -f "$TARGET/docs/project-status.md" ]]; then
  had_project_status=1
fi

# Root kit files (README handled separately)
for f in AGENTS.md CLAUDE.md TOOLING.md VERSION CONTRIBUTING.md SECURITY.md CHANGELOG.md LICENSE .gitignore; do
  copy_file "$f"
done

# Optional kit docs for operators of the method
copy_file "README.md" "README.kit.md"

if [[ ! -f "$TARGET/README.md" || "$FORCE" -eq 1 ]]; then
  if [[ -f "$TARGET/README.md" && "$FORCE" -eq 1 ]]; then
    kit_info "force: leaving product README strategy to stub overwrite"
  fi
  if [[ ! -f "$TARGET/README.md" || "$FORCE" -eq 1 ]]; then
    cat > "$TARGET/README.md" <<EOF
# Project

This repository uses the **agent operating kit** (version $(tr -d '[:space:]' < "$ROOT/VERSION")).

| Resource | Path |
| --- | --- |
| Rules | \`AGENTS.md\` |
| Skills | \`.agents/skills/\` |
| Status | \`docs/project-status.md\` |
| Profiles | \`profiles/\` |
| Verify | \`./scripts/verify\` |
| Kit guide | \`README.kit.md\` |
| Completeness | \`docs/kit/completeness.md\` |
| Script contracts | \`docs/kit/scripts.md\` |

\`\`\`text
kit_version: $(tr -d '[:space:]' < "$ROOT/VERSION")
\`\`\`

Empty documentation sections mean **not decided**, not unrestricted scope.
EOF
    kit_ok "wrote project README.md stub"
  fi
else
  kit_info "skip existing: README.md"
fi

# Core trees
copy_tree ".agents" ".agents"
copy_tree "profiles" "profiles"
copy_tree "adapters" "adapters"
copy_tree "scripts" "scripts"
copy_tree "contracts" "contracts"
copy_tree "docs" "docs"

# GitHub template + workflow (useful defaults; project may replace CI)
copy_file ".github/pull_request_template.md"
copy_file ".github/workflows/kit-ci.yml" ".github/workflows/kit-ci.yml"

# Executables
if [[ -d "$TARGET/scripts" ]]; then
  chmod +x "$TARGET"/scripts/check-docs "$TARGET"/scripts/verify "$TARGET"/scripts/test \
    "$TARGET"/scripts/list-skills "$TARGET"/scripts/bootstrap-project 2>/dev/null || true
fi

# Instances must not inherit the kit repository's own project-status.
# Use the blank template unless the target already had a status (and no --force).
if [[ -f "$ROOT/docs/_templates/project-status.md" ]]; then
  if [[ "$had_project_status" -eq 0 || "$FORCE" -eq 1 ]]; then
    mkdir -p "$TARGET/docs"
    cp "$ROOT/docs/_templates/project-status.md" "$TARGET/docs/project-status.md"
    kit_ok "installed docs/project-status.md from template (instance, not kit status)"
  else
    kit_info "kept pre-existing docs/project-status.md"
  fi
fi

{
  echo "# Kit bootstrap stamp"
  echo
  echo "- kit_version: $(tr -d '[:space:]' < "$ROOT/VERSION")"
  echo "- bootstrapped_at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  echo "- source: agent operating kit"
  echo "- completeness: see docs/kit/completeness.md"
} > "$TARGET/docs/kit-version.md"
kit_ok "wrote docs/kit-version.md"

kit_log "bootstrap: done"
kit_info "next: edit docs/project-status.md; run ./scripts/check-docs; then discover-product or audit-existing-project"
exit "$KIT_EXIT_OK"
